---
// MARK: Bron -> https://api.nasa.gov/

// MARK: Server Side JS
import "../styles/style.css";

const apiKey = import.meta.env.NASA_API_KEY;
const nu = new Date();
const jaar = nu.getFullYear();
const maand = nu.getMonth();
const dag = nu.getDate();

const eersteDag = new Date(jaar, maand, dag);
const laatsteDag = new Date(jaar, maand, dag + 7);

// Aan gemini gevraagt waarom alleObjectenVanDeMaand een error geeft: hij doet het maar het geeft een error dat het niet assignable is als never?
// Gemini zei: Dat is een heel bekend en irritant dingetje in TypeScript en Astro! De reden dat je een rood kringeltje of een error krijgt (terwijl de code in je browser stiekem wel gewoon werkt), heeft te maken met type-inferentie.
// Oplossing: Door er as any[] achter te zetten, houdt TypeScript direct zijn mond en verdwijnt de error.

let alleObjectenVanDeMaand = [] as any[];
let huidigeStart = new Date(eersteDag);
let huidigeEind = new Date(huidigeStart);

while (huidigeStart <= laatsteDag) {
	huidigeEind.setDate(huidigeEind.getDate() + 6);

	if (huidigeEind > laatsteDag) {
		huidigeEind = new Date(laatsteDag);
	}

	const startStr = `${huidigeStart.getFullYear()}-${String(huidigeStart.getMonth() + 1).padStart(2, "0")}-${String(huidigeStart.getDate()).padStart(2, "0")}`;
	const eindStr = `${huidigeEind.getFullYear()}-${String(huidigeEind.getMonth() + 1).padStart(2, "0")}-${String(huidigeEind.getDate()).padStart(2, "0")}`;

	const response = await fetch(
		`https://api.nasa.gov/neo/rest/v1/feed?start_date=${startStr}&end_date=${eindStr}&api_key=${apiKey}`,
	);

	if (!response.ok) {
		console.error("NASA API Error:", response.status, response.statusText);
		break;
	}

	const data = await response.json();

	if (huidigeEind > laatsteDag) {
		huidigeEind = new Date(laatsteDag);
	}

	if (data.near_earth_objects) {
		for (const datum in data.near_earth_objects) {
			const gefilterdeObjecten = data.near_earth_objects[datum].filter(
				(obj: any) => {
					return obj.close_approach_data.some((approach: any) => {
						const isEarth = approach.orbiting_body === "Earth";
						const afstand = parseFloat(
							approach.miss_distance.kilometers,
						);
						return isEarth && afstand < 10500000;
					});
				},
			);

			const objectenMetDatum = gefilterdeObjecten.map((obj: any) => ({
				...obj,
				naderingsDatum: datum,
			}));

			alleObjectenVanDeMaand = [
				...alleObjectenVanDeMaand,
				...objectenMetDatum,
			];
		}
	}

	huidigeStart = new Date(huidigeEind);
	huidigeStart.setDate(huidigeStart.getDate() + 1);
}

function getDistanceColor(afstand: number): string {
	switch (true) {
		case afstand < 20000:
			return "240, 34, 34, 0.251";
			break;

		case afstand < 2000000:
			return "240, 34, 34";
			break;

		case afstand < 4000000:
			return "165, 211, 129";
			break;

		case afstand < 6000000:
			return "129, 211, 182";
			break;

		case afstand < 8000000:
			return "129, 143, 211";
			break;

		default:
			return "75, 222, 238";
	}
}

const formatter = new Intl.NumberFormat("de-DE", {
	style: "unit",
	unit: "kilometer",
	unitDisplay: "short",
	maximumFractionDigits: 0,
});

alleObjectenVanDeMaand.sort((a, b) =>
	a.naderingsDatum.localeCompare(b.naderingsDatum),
);
---

<!-- MARK: HTML -->
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Astro</title>
	</head>
	<body>
		<canvas id="distanceCircles"></canvas>
		<div id="earth-container">
			<div class="sattelite-container">
				<span class="tooltiptext">Satelliet - 18.000 km</span>
				<img class="sattelite" src="./images/Satellite_Image.png" />
			</div>
			<div class="sattelite-container">
				<span class="tooltiptext"
					>James Webb Telescope - 1.500.000 km</span
				>
				<img
					class="sattelite"
					src="./images/James_Webb_Telescope.png"
				/>
			</div>
		</div>

		<h1>NASA Data - NEO (Nearby Earth Objects)</h1>
		<div id="control-panel">
			<button type="button" id="center-btn" class="ui-button">
				Center Earth
			</button>
		</div>
		{
			alleObjectenVanDeMaand.length > 0 ? (
				<div class="asteroid-container" id="card-layer">
					{alleObjectenVanDeMaand.map((astroide, index) => {
						const afstand = parseFloat(
							astroide.close_approach_data[0].miss_distance
								.kilometers,
						);
						const rgbKleur = getDistanceColor(afstand);

						return (
							<div class="asteroid-card" data-distance={afstand}>
								<button
									type="button"
									class="open-btn"
									popovertarget={`popover-${astroide.id}`}
								>
									<span class="tooltiptext">
										Naam: {astroide.name}
									</span>
									<img
										src="./images/HT_Star.png"
										alt="Asteroid"
									/>
								</button>

								<dialog
									id={`popover-${astroide.id}`}
									popover
									style={`--distance-color: ${rgbKleur};`}
								>
									<img
										src="./images/HT_Star.png"
										alt="Asteroid Detail"
									/>
									<div class="text">
										<h2>Naam: {astroide.name}</h2>

										<div id="value-container">
											<h2>Datum</h2>
											<p>
												{
													astroide
														.close_approach_data[0]
														.close_approach_date_full
												}
											</p>
										</div>

										<div id="value-container">
											<h2>Breedte (Geschat):</h2>
											<p>
												Minimaal{" "}
												{Math.round(
													astroide.estimated_diameter
														.meters
														.estimated_diameter_min,
												)}{" "}
												meter
											</p>
											<p>
												Maximaal{" "}
												{Math.round(
													astroide.estimated_diameter
														.meters
														.estimated_diameter_max,
												)}{" "}
												meter
											</p>
										</div>

										<div id="value-container">
											<h2>Snelheid:</h2>
											<p>
												{formatter.format(
													Math.round(
														astroide
															.close_approach_data[0]
															.relative_velocity
															.kilometers_per_hour,
													),
												)}
												/u
											</p>
										</div>

										<div id="value-container">
											<h2>Potentieel gevaarlijk:</h2>
											<p>
												{astroide.is_potentially_hazardous_asteroid
													? "Ja"
													: "Nee"}
											</p>
										</div>

										<div id="value-container">
											<h2>Afstand:</h2>
											<p>
												{formatter.format(
													Math.round(
														astroide
															.close_approach_data[0]
															.miss_distance
															.kilometers,
													),
												)}
											</p>
										</div>

										<button
											type="button"
											class="close-btn"
											popovertarget={`popover-${astroide.id}`}
										>
											Sluiten
										</button>
									</div>
								</dialog>
							</div>
						);
					})}
				</div>
			) : (
				<p>
					Er worden momenteel geen gegevens geladen of er zijn geen
					naderingen deze maand.
				</p>
			)
		}

		{/* MARK: Client side JS */}
		<script src="/src/js/stars.js"></script>
		<script>
			let offsetX = 0;
			let offsetY = 0;
			let isDragging = false;
			let lastMouseX = 0;
			let lastMouseY = 0;

			const canvas = document.getElementById(
				"distanceCircles",
			) as HTMLCanvasElement;
			const ctx = canvas?.getContext("2d");

			const circle = [
				{ r: 85, color: "#F0222250", afstand: "0" },
				{ r: 120, color: "#F0222240", afstand: "20.000" },
				{ r: 250, color: "#F02222", afstand: "2.000.000" },
				{ r: 375, color: "#A5D381", afstand: "4.000.000" },
				{ r: 500, color: "#81D3B6", afstand: "6.000.000" },
				{ r: 625, color: "#818FD3", afstand: "8.000.000" },
				{ r: 750, color: "#4BDEEE", afstand: "10.000.000" },
			];

			const Nebula_color_1 = '#03041b';
			const Nebula_color_2 = '#4d0d7e4d';
			const Nebula_color_3 = '#000000c4'; 
			const NEBULA_BLOB_COUNT = 30; 

			const earthImg = new Image();
			earthImg.src = "./images/Earth.png";

			// MARK: Functions
			// Met behulp van https://codepen.io/beejaymorgan/pen/rjPwmL
			function createNebulaGradient() {
				let gradient_array = [];

				for (let i = 0; i < NEBULA_BLOB_COUNT; i++) {
					const x = Math.round(Math.random() * 100);
					const y = Math.round(Math.random() * 100);
					const color = Math.random() < 0.33 ? Nebula_color_1 : Math.random() < 0.66 ? Nebula_color_2 : Nebula_color_3;
					const gradient = `radial-gradient(circle at ${x}% ${y}%, ${color} 0%, transparent 30%)`;
					
					// Push gebruikt om de gradient toe te voegen aan de array https://www.w3schools.com/js/js_const.asp
					gradient_array.push(gradient);
				}

				return gradient_array.join(',');
			}

			function applyNebula() {
				const nebulaGradient = createNebulaGradient();
				const sections = document.querySelectorAll('body');

				sections.forEach((section, index) => {
					if (section.id === 'info') {
						return; 
					}
					
					section.style.backgroundImage = nebulaGradient;
					section.style.backgroundAttachment = 'fixed';
					section.style.transition = 'background-image 0.5s ease';
					
				});
			}

			applyNebula();

			function drawCircles() {
				if (!canvas || !ctx) return;

				canvas.width = window.innerWidth;
				canvas.height = window.innerHeight;

				const middenX = canvas.width / 2 + offsetX;
				const middenY = canvas.height / 2 + offsetY;

				ctx.clearRect(0, 0, canvas.width, canvas.height);

				ctx.imageSmoothingEnabled = true;
				ctx.imageSmoothingQuality = 'high';

				circle.forEach((cirkel, index) => {
					ctx.beginPath();
					ctx.arc(middenX, middenY, cirkel.r, 0, 2 * Math.PI);

					if (index === 1) {
						ctx.fillStyle = circle[0].color;
						ctx.fill();
					}

					ctx.strokeStyle = cirkel.color;
					ctx.lineWidth = 1;
					ctx.stroke();

					ctx.font = "20px NasaFont";
					ctx.fillStyle = cirkel.color;
					ctx.textAlign = "center";

					ctx.save();
					ctx.translate(middenX - cirkel.r, middenY);
					ctx.rotate(-Math.PI / 2);
					ctx.fillText(cirkel.afstand + " km", 0, 50);
					ctx.restore();
				});

								const earthSize = 200;
				if (earthImg.complete) {
					ctx.drawImage(
						earthImg, 
						middenX - earthSize / 2, 
						middenY - earthSize / 2, 
						earthSize, 
						earthSize
					);
				} else {
					// Als hij nog laadt, teken hem zodra hij klaar is
					earthImg.onload = () => drawCircles();
				}
			}

			function positionCards() {
				const cards = document.querySelectorAll(".asteroid-card");
				const earth = document.getElementById("earth-container");
				const middenX = window.innerWidth / 2 + offsetX;
				const middenY = window.innerHeight / 2 + offsetY;

				if (earth) {
					earth.style.left = `${middenX}px`;
					earth.style.top = `${middenY}px`;
					earth.style.transform = `translate(-50%, -50%)`;
				}

				const circlesData = [
					{ r: 125, km: 0 },
					{ r: 160, km: 20000 },
					{ r: 250, km: 2000000 },
					{ r: 375, km: 4000000 },
					{ r: 500, km: 6000000 },
					{ r: 625, km: 8000000 },
					{ r: 750, km: 10000000 },
				];

				function getRadiusByDistance(afstand: number): number {
					for (let i = 0; i < circlesData.length - 1; i++) {
						const start = circlesData[i];
						const eind = circlesData[i + 1];
						if (afstand >= start.km && afstand <= eind.km) {
							const percentage =
								(afstand - start.km) / (eind.km - start.km);
							return start.r + percentage * (eind.r - start.r);
						}
					}
					return circlesData[circlesData.length - 1].r;
				}

				cards.forEach((card, index) => {
					const htmlCard = card as HTMLElement;
					const afstand = parseFloat(
						htmlCard.dataset.distance || "0",
					);
					const straalInPixels = getRadiusByDistance(afstand);
					const hoek = index * 137.5 * (Math.PI / 180);
					const x = middenX + straalInPixels * Math.cos(hoek);
					const y = middenY + straalInPixels * Math.sin(hoek);
					const rotatie = hoek + Math.PI;

					htmlCard.style.left = `${x}px`;
					htmlCard.style.top = `${y}px`;
					htmlCard.style.setProperty(
						"--astro-rotatie",
						`${rotatie}rad`,
					);
					htmlCard.style.transform = `translate(-50%, -50%) rotate(var(--astro-rotatie))`;
				});
			}

			window.addEventListener("load", () => {
				drawCircles();
				positionCards();
			});

			window.addEventListener("resize", () => {
				drawCircles();
				positionCards();
			});

			const SLEEP_GRENS = 500;

			window.addEventListener("mousemove", (e) => {
				if (!isDragging) return;

				const deltaX = e.clientX - lastMouseX;
				const deltaY = e.clientY - lastMouseY;

				offsetX = Math.min(
					Math.max(offsetX + deltaX, -SLEEP_GRENS),
					SLEEP_GRENS,
				);
				offsetY = Math.min(
					Math.max(offsetY + deltaY, -SLEEP_GRENS),
					SLEEP_GRENS,
				);

				lastMouseX = e.clientX;
				lastMouseY = e.clientY;

				drawCircles();
				positionCards();
			});

			const centerBtn = document.getElementById("center-btn");
			centerBtn?.addEventListener("click", () => {
				offsetX = 0;
				offsetY = 0;

				drawCircles();
				positionCards();
			});

			window.addEventListener("mousedown", (e) => {
				if (
					(e.target as HTMLElement).closest("button") ||
					(e.target as HTMLElement).closest("dialog")
				)
					return;
				isDragging = true;
				lastMouseX = e.clientX;
				lastMouseY = e.clientY;
			});

			window.addEventListener("mouseup", () => {
				isDragging = false;
			});
		</script>
		<div id="scroll-anchor"></div>
	</body>
</html>
